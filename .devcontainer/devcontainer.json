{
  "name": "Vercel OSS Bug Hunting",
  "image": "mcr.microsoft.com/devcontainers/universal:2",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "stable"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    }
  },

  "postCreateCommand": "set -euo pipefail; corepack enable; corepack prepare pnpm@latest --activate; sudo apt-get update; sudo apt-get install -y jq ripgrep fd-find hyperfine; rustup component add clippy rustfmt; cargo install --locked cargo-audit cargo-deny cargo-expand cargo-nextest || true; echo 'Setup done.'",

  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "serayuzgur.crates",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true,
        "rust-analyzer.check.command": "clippy"
      }
    }
  },

  "remoteUser": "codespace"
}
